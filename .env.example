# Facebook App 配置
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/callback

# JWT 密钥
JWT_SECRET=your_jwt_secret_change_in_production

# 服务端口
SERVER_PORT=3000
CLIENT_PORT=5173

# Facebook API 版本
FACEBOOK_API_VERSION=v19.0

# PostgreSQL 数据库
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=fb_auto_analytics
PG_SSL=false

# Facebook API 代理（可选）
FB_PROXY=

# Shoplazza 店铺库（与 PG 同连接，仅库名不同）
SHOPLAZZA_PG_DATABASE=shoplazza
SHOPLAZZA_API_VERSION=2025-06
SHOPLAZZA_TIME_ZONE=8
